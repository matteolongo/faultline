{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Demo: arctic_cable_bypass",
      "type": "debugpy",
      "request": "launch",
      "module": "strategic_swarm_agent",
      "args": ["run-demo", "--scenario", "arctic_cable_bypass"],
      "cwd": "${workspaceFolder}",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/src"
      },
      "envFile": "${workspaceFolder}/.env",
      "console": "integratedTerminal",
      "justMyCode": false
    },
    {
      "name": "Demo: debt_defense_spiral",
      "type": "debugpy",
      "request": "launch",
      "module": "strategic_swarm_agent",
      "args": ["run-demo", "--scenario", "debt_defense_spiral"],
      "cwd": "${workspaceFolder}",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/src"
      },
      "envFile": "${workspaceFolder}/.env",
      "console": "integratedTerminal",
      "justMyCode": false
    },
    {
      "name": "Demo: open_model_breakout",
      "type": "debugpy",
      "request": "launch",
      "module": "strategic_swarm_agent",
      "args": ["run-demo", "--scenario", "open_model_breakout"],
      "cwd": "${workspaceFolder}",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/src"
      },
      "envFile": "${workspaceFolder}/.env",
      "console": "integratedTerminal",
      "justMyCode": false
    },
    {
      "name": "Live: last 60 minutes",
      "type": "debugpy",
      "request": "launch",
      "module": "strategic_swarm_agent",
      "args": ["run-latest", "--lookback-minutes", "60"],
      "cwd": "${workspaceFolder}",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/src"
      },
      "envFile": "${workspaceFolder}/.env",
      "console": "integratedTerminal",
      "justMyCode": false
    },
    {
      "name": "Provider Health Check",
      "type": "debugpy",
      "request": "launch",
      "module": "strategic_swarm_agent",
      "args": ["provider-health"],
      "cwd": "${workspaceFolder}",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/src"
      },
      "envFile": "${workspaceFolder}/.env",
      "console": "integratedTerminal",
      "justMyCode": false
    },
    {
      "name": "Run All Demos + Evaluate",
      "type": "debugpy",
      "request": "launch",
      "module": "strategic_swarm_agent",
      "args": ["run-all-demos"],
      "cwd": "${workspaceFolder}",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/src"
      },
      "envFile": "${workspaceFolder}/.env",
      "console": "integratedTerminal",
      "justMyCode": false
    },
    {
      "name": "pytest: all tests",
      "type": "debugpy",
      "request": "launch",
      "module": "pytest",
      "args": ["-v", "--tb=short"],
      "cwd": "${workspaceFolder}",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/src"
      },
      "envFile": "${workspaceFolder}/.env",
      "console": "integratedTerminal",
      "justMyCode": false
    },
    {
      "name": "pytest: current file",
      "type": "debugpy",
      "request": "launch",
      "module": "pytest",
      "args": ["-v", "--tb=short", "${file}"],
      "cwd": "${workspaceFolder}",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/src"
      },
      "envFile": "${workspaceFolder}/.env",
      "console": "integratedTerminal",
      "justMyCode": false
    }
  ]
}
